/*下面是latex*/
    "[latex]": {
        "editor.defaultFormatter": "James-Yu.latex-workshop"
    },

    // 编译方案，这里定义了三个方案
    "latex-workshop.latex.recipes": 
    [
        // 第一个方案，只使用 pdflatex
        {"name": "xelatex",
        "tools": [
        "xelatex"
        ]
        },

        // 第二个方案，用于带参考文献的论文的编译
        {"name": "xelatex ➞ bibtex ➞ xelatex`×2",     //bibtex是参考文献管理工具
        "tools": [
            "xelatex",
            "bibtex",
            "xelatex",
            "xelatex"
        ]
        },

        //第三个方案（坑死我的没有设置latexmk)
        {
            "name": "latexmk 🔃",
            "tools": [
              "latexmk"
            ]
          },
    ],

   // 编译方案中所需的编译工具，包含 xelatex 和 bibtex
   "latex-workshop.latex.tools": [

    {
        "name": "latexmk",
        "command": "latexmk",
        // "args": [
        //     "-synctex=1",
        //     "-interaction=nonstopmode",
        //     "-file-line-error",
        //     "-pdf",
        //     "-outdir=%OUTDIR%",
        //     "%DOC%"
        // ],
        "args": [
            "-xelatex",
            "-synctex=1",
            "-interaction=nonstopmode",
            "-file-line-error",
            "%DOC%"
        ],
        "env": {}
      },

      {
        "name": "xelatex",
        "command": "xelatex",
        "args": [
            "-synctex=1",
            "-interaction=nonstopmode",
            "-file-line-error",
            "%DOC%"
        ]
    },
   
    {
        "name": "bibtex",
        "command": "bibtex",
        "args": [
            "%DOCFILE%"
        ]
    }
],
    // 将自己编写的宏包路径添加到宏包搜索路径中（好吧，latex-workshop没有这个参数，实际上只需要将宏包安装到TexLive中即可）
    "latex-workshop.latex.search.path":[
        "C:\\Users\\10456\\Desktop\\note\\repo\\Latex\\宏包",
        "C:\\Users\\10456\\Desktop\\note\\repo\\Latex\\文档类"
    ],
    // 编译错误时不显示警告弹窗
    "latex-workshop.message.error.show"  : false,
    "latex-workshop.message.warning.show": false,
    // 打开pdf阅读器
    "latex-workshop.view.pdf.viewer": "tab",
    // 两次自动编译最小间隔时间为 10 秒，免得每次保存都要重新编译
    "latex-workshop.latex.autoBuild.interval": 10000,
    // 默认使用上一次的编译方案
    "latex-workshop.latex.recipe.default": "lastUsed",
    // 每次编译后删除辅助文件
    "latex-workshop.latex.autoClean.run": "onBuilt",
    "latex-workshop.view.pdf.hand": true,
    "editor.wordWrap": "on",
    // 双击鼠标即可跳转到tex文件中相应位置
    "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",
    //SpellRight插件设置
    "spellright.language": [
        "en",
        "zh-cn"
    ],
    //是否检查拼写规范
    "spellright.documentTypes": [
        "plaintext",
        "latex"
    ],

