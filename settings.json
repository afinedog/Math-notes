/*下面是code runner*/
    "code-runner.clearPreviousOutput": true,
    "code-runner.executorMapByGlob": {
        "pom.xml": "cd $dir && mvn clean package"
    },
    "code-runner.executorMap": {
        "java": "cd $dir && javac -encoding utf-8 $fileName && java $fileNameWithoutExt"
    },
    "files.autoSave": "afterDelay",


/*下面是宏命令*/
    "macros.list": {
        /*两端添加颜色标签*/ //暂时废弃了，因为要保存原先的，太难了
        "font-orange": [
            //"cursorFocusLeft",
            {"command": "cursorMove","args": {"to": "left","by": "selection","value": 1,"select": false},"when": "editorTextFocus && editorHasSelection"},
            //打字左括号
            {
                "command": "type",
                "args": {"text": "<font color='orange'>"},
            },
            //cursorFocusRight
            {"command": "cursorMove","args": {"to": "right","by": "selection","value": 1,"select": false},"when": "editorTextFocus && editorHasSelection"},
            {
                "command": "type",
                "args": {"text": "</font>"}

            }
        ],
        "font-red": [
            //"cursorEnd",
            {"command": "type","args": {"text": "<font color='red'></font>" }},
            "cursorWordLeft","cursorLeft","cursorLeft"
        ],
        "font-green": [
            //"cursorEnd",
            {"command": "type","args": {"text": "<font color='chartreuse'></font>" }},
            "cursorWordLeft","cursorLeft","cursorLeft"
        ],
        "font-aqua": [
            //"cursorEnd",
            {"command": "type","args": {"text": "<font color='aqua'></font>" }},
            "cursorWordLeft","cursorLeft","cursorLeft"
        ],
        //两端添加引号
        "quotation-mark":[
            "cursorWordLeft",{"command": "type", "args": {"text": "'"}},
            "cursorWordRight",{"command": "type", "args": {"text": "'"}},
        ],
        // 快捷键 ctrl+k, j
        "union-type":[
            {"command": "type","args": {"text": "\\mathop{\\bigcup}\\limits^\\infty_{i=1}"}}
        ],
        // 快捷键 ctrl+k, s
        "sum-type":[
            {"command": "type","args": {"text": "\\sum\\limits^\\infty_{i=1}"}}
        ],
        // 快捷键 ctrl+k, h
        "set-type":[
            {"command": "type","args": {"text": "E\\{x\\mid f(x)>a\\}"}}
        ],
        // 快捷键 ctrl+k, t
        "topo-type":[
            {"command": "type","args": {"text": "\\prod\\limits_{\\alpha\\in J}}"}}
        ],
        // 快捷键 ctrl+k, l
        "upper-limit":[
            {"command": "type", "args": {"text":"\\lim\\limits_{n\\to\\infty}"}},
        ],
        // 快捷键 ctrl+k, k
        "inner-product":[
            {"command": "type", "args": {"text":"\\lang  \\rang"}},
            "cursorWordLeft","cursorLeft","cursorLeft"
        ],
        // 快捷键 ctrl+k, v
        "square-bracket":[
            {"command": "type", "args": {"text":"\\Big[  \\Big]"}},
            "cursorLeft","cursorWordLeft","cursorLeft","cursorLeft"
        ],
        // 快捷键 ctrl+l, b
        "adapt-bracket":[
            {"command": "type", "args": {"text":"\\Big(  \\Big)"}},
            "cursorLeft","cursorWordLeft","cursorLeft","cursorLeft"
        ],
        //快捷键 ctrl+k, f
        "large-fraction":[
            {"command": "type", "args": {"text":"\\cfrac{\\partial }{\\partial }"}},
            "cursorLeft","cursorWordLeft","cursorLeft","cursorLeft","cursorLeft"
        ],
        // 快捷键 ctrl+k, n
        "large-norm":[
            {"command": "type", "args": {"text":"\\biggm|  \\biggm|"}},
            "cursorLeft","cursorWordLeft","cursorLeft","cursorLeft"
        ],
        // 快捷键 ctrl+k, q
        "group-product":[
            {"command": "type", "args": {"text":"\\prod\\limits_{i\\in I}\\\\^w G_i"}},
        ],
        // 快捷键 ctrl+l, v
        "circ-bracket":[
            {"command": "type", "args": {"text":"\\big(  \\big)"}},
            "cursorLeft","cursorWordLeft","cursorLeft","cursorLeft"
        ],
        // 一键将行内改为块状注释（只有在js和java代码块中才有效）
        "block-comment":[
            {"command": "cursorMove" ,"args": {"to": "wrappedLineStart"}},
            {"command": "type", "args": {"text":"/**\n"}},
            {"command": "cursorMove" ,"args": {"to": "down", }},
            {"command": "cursorMove" ,"args": {"to": "wrappedLineStart"}},
            {"command": "type", "args": {"text":"*/\n"}},
            {"command": "cursorMove" ,"args": {"to": "up"}},
            {"command": "cursorMove" ,"args": {"to": "up"}},
            {"command": "cursorMove" ,"args": {"to": "wrappedLineEnd"}}
        ],
    },
